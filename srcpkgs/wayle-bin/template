# Template file for 'wayle'
pkgname=wayle
version=0.2.3
revision=1
#archs="i686 x86_64"
#build_wrksrc=
build_style="fetch"
#configure_args=""
#make_build_args=""
#make_install_args=""
#conf_files=""
#make_dirs="/var/log/dir 0755 root root"
#hostmakedepends=""
#makedepends=""
depends="gtk4 gtk4-layer-shell gtksourceview5 pulseaudio fftw pipewire eudev-libudev upower NetworkManager bluez power-profiles-daemon swww matugen pywal"
short_desc="Wayland desktop shell written in Rust with GTK4 and Relm4."
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="MIT"
homepage="https://wayle.app"
changelog="https://github.com/wayle-rs/wayle/releases"
distfiles="https://github.com/wayle-rs/wayle/releases/download/v0.2.3/${pkgname}-${version}-x86_64-linux.tar.gz"
checksum=c3adb3c1cb3d4a828e0c7a2ae3e0f85be84abd2bb76e3800008faf8de0596aca
repository=d77

do_install() {
	vextract ${pkgname}*.tar.gz
	vmkdir /usr/bin
	vmkdir /usr/share/applications
	vmkdir /usr/share/bash-completion/completions
	vmkdir /usr/share/zsh/site-functions
	vmkdir /usr/share/fish/vendor_completions.d
	vmkdir /usr/share/icons/hicolor/scalable/apps/
	vmkdir /usr/share/icons/hicolor/scalable/actions/
	vmkdir /usr/share/licenses/${pkgname}
	vcopy ${pkgname} /usr/bin/
	vcopy ${pkgname}-settings /usr/bin/
	vcopy LICENSE /usr/share/licenses/${pkgname}/
	vcopy completions/completions.bash /usr/share/bash-completion/completions/${pkgname}
	vcopy completions/_${pkgname} /usr/share/zsh/site-functions/_${pkgname}
	vcopy completions/${pkgname}.fish /usr/share/fish/vendor_completions.d/${pkgname}.fish
	vcopy ${pkgname}-settings.svg  /usr/share/icons/hicolor/scalable/apps/
	vcopy com.wayle.settings.desktop /usr/share/applications/
	vcopy icons/hicolor/scalable/actions/'*' /usr/share/icons/hicolor/scalable/actions/
}
